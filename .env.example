# Singularity daemon — machine-specific config. REQUIRED: the daemon has NO
# baked-in defaults, so copy this to `.env` (gitignored) and fill in real values.
# Loaded by `node --env-file-if-exists=.env` in the server/start/dev/ollama-login
# scripts (Node >= 20.12). Missing `.env` or any REQUIRED var → the daemon
# refuses to start with a clear list. Node --env-file does NOT expand ~ or
# $HOME — use absolute paths (forward slashes OK on Windows: C:/Users/...).
#
# First-time setup: `pnpm bootstrap` generates a `.env` from this template
# (detects CLAUDE_BIN, defaults SINGULARITY_HOME=~/.singularity + PORT=4317),
# runs install, and starts the app.

# REQUIRED. Runtime state root. State under state/, cache under cache/.
SINGULARITY_HOME=/absolute/path/.singularity

# REQUIRED. Loopback listen port.
PORT=4317

# REQUIRED. Absolute path to the claude executable (no PATH fallback —
# Windows node-pty does no PATH resolution).
CLAUDE_BIN=/absolute/path/claude.exe

# OPTIONAL. Absolute path to the ollama executable. Absent → ollama models
# unavailable (clear spawn error), daemon boots fine.
OLLAMA_BIN=/absolute/path/ollama.exe

# OPTIONAL. Skill-scopes surface root (used to --add-dir scopes into agents).
# Author-specific layout. Vanilla users: leave unset — the skills viewer
# auto-detects ~/.claude/skills + <project>/.claude/skills (flat or grouped).
SING_SCOPE_ROOT=/absolute/path/.agents/skill-scopes

# OPTIONAL (claude-code-usage-report skill). Absent → spend/usage-report
# degrade silently; the daemon boots fine. /capabilities reports availability.
SING_USAGE_SKILL=/absolute/path/claude-code-usage-report/scripts/stats.mjs

# OPTIONAL (claude-code-usage-report skill). Spend-report output dir.
SING_USAGE_REPORTS=/absolute/path/.agents/.claude-code-usage-report/reports

# OPTIONAL. Trusted root for .worktrees/ + .tickets/ (default = this clone).
# Set for a global/npx/shared install where the clone isn't writable.
#SING_TRUSTED_ROOT=

# OPTIONAL. Auth token gating data endpoints + WS. Unset = open (loopback only).
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
#SING_TOKEN=