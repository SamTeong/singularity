{
  "name": "singularity",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20.12" },
  "scripts": {
    "bootstrap": "node --env-file-if-exists=.env scripts/bootstrap.mjs",
    "server": "node --env-file-if-exists=.env server/index.mjs",
    "web": "node --env-file-if-exists=.env node_modules/vite/bin/vite.js --config web/vite.config.mjs",
    "build": "vite build --config web/vite.config.mjs",
    "dev": "concurrently -k \"npm:server\" \"npm:web\"",
    "start": "npm run build && npm run server",
    "ollama-login": "node --env-file-if-exists=.env scripts/ollama-login.mjs",
    "test": "node --test --test-force-exit \"server/*.test.mjs\""
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/view": "^6.43.6",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fastify/static": "^9.3.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@uiw/react-codemirror": "^4.25.11",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "@zapac/mui-theme": "file:vendor/zapac-mui-theme-0.2.0.tgz",
    "cron-parser": "^5.6.2",
    "cronstrue": "^3.24.0",
    "cytoscape": "^3.34.0",
    "cytoscape-fcose": "^2.2.0",
    "fastify": "^5.10.0",
    "mermaid": "^11.16.0",
    "node-pty": "^1.1.0",
    "playwright-core": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.4",
    "vite": "^6.4.3"
  }
}
