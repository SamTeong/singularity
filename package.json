    "@fastify/static": "^8.3.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@uiw/react-codemirror": "^4.25.11",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@zapac/mui-theme": "file:../_references/zapac-material-ui/zapac-mui-theme-0.1.0.tgz",
    "fastify": "^5.10.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.0"
  },
